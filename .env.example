# ===================================
# eMuhasebe Pro - Ortam Değişkenleri
# ===================================
# Not: .env dosyasını kopyala ve değerlerini doldur
# .env dosyası asla Git'e commit edilmemeli

# ─── Flask Ayarları ───
FLASK_ENV=development
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-here-32-characters-minimum

# ─── Veritabanı ───
# Geliştirme: SQLite kullanılır (config.py'de ayarlı)
# Üretim: PostgreSQL/MySQL için DATABASE_URL
DATABASE_URL=sqlite:///instance/muhasebe.db

# ─── Firebase (Frontend/Client-side) ───
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123def456

# ─── Güvenlik ───
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# ─── Logging ───
LOG_LEVEL=INFO
LOG_DIR=logs
# LOG_LEVEL seçenekleri: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG: Detaylı debug bilgisi (geliştirme için)
# INFO: Önemli olaylar
# WARNING: Uyarılar ve beklenmedik durumlar
# ERROR: Hatalar
# CRITICAL: Kritik hatalar

# ─── Email (İleride) ───
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
